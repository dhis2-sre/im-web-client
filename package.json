{
    "name": "instance-manager",
    "packageManager": "yarn@4.9.0",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "start": "vite --port 3000",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "test": "jest test",
        "eslint": "eslint --report-unused-disable-directives --max-warnings 0",
        "prettier": "prettier .",
        "lint": "yarn eslint && yarn prettier --check",
        "format": "yarn eslint --fix && yarn prettier --write",
        "e2e": "yarn playwright test --ui",
        "generate-types": "rm -rf ./src/types/generated && yarn openapi --input https://api.im-dev.dhis2.org/swagger.yaml --output ./src/types/generated --client axios --useOptions --useUnionTypes --exportCore false --exportServices false --exportModels true --exportSchemas false && yarn prettier --write --loglevel silent",
        "lint-commit-msg": "npx --no-install commitlint --edit",
        "postinstall": "husky install",
        "pre-commit": "yarn format && yarn lint",
        "prepare": "husky install"
    },
    "dependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@dhis2/app-runtime": "^3.17.0",
        "@dhis2/app-service-alerts": "^3.17.0",
        "@dhis2/d2-i18n": "^1.2.0",
        "@dhis2/data-engine": "^3.17.0",
        "@dhis2/ui": "^10.7.2",
        "@fontsource/roboto": "^5.2.10",
        "axios": "^1.16.1",
        "axios-hooks": "^5.1.1",
        "final-form": "^5.0.0",
        "moment": "^2.30.1",
        "pretty-bytes": "^7.1.0",
        "prop-types": "^15.8.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-final-form": "^7.0.1",
        "react-moment": "^1.1.3",
        "react-router-dom": "^6.30.3",
        "styled-jsx": "^4.0.1",
        "typescript": "6.0.3",
        "use-debounce": "^10.1.1",
        "web-vitals": "^4.2.3"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.5",
        "@babel/preset-react": "^7.28.5",
        "@eslint/compat": "^2.0.0",
        "@eslint/js": "^10.0.0",
        "@ls-lint/ls-lint": "^2.3.1",
        "@playwright/test": "1.60.0",
        "@testing-library/dom": "^10.0.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.5.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.5.2",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@types/react-router-dom": "^5.3.3",
        "@typescript-eslint/eslint-plugin": "^8.59.4",
        "@typescript-eslint/parser": "^8.59.4",
        "@vitejs/plugin-react": "^6.0.2",
        "dotenv": "^17.4.2",
        "dotenv-expand": "^13.0.0",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "openapi-typescript-codegen": "^0.30.0",
        "prettier": "^3.8.3",
        "ts-jest": "^29.4.11",
        "typescript-eslint": "^8.59.4",
        "vite": "8.0.13"
    },
    "resolutions": {
        "@dhis2/multi-calendar-dates": "2.1.2",
        "styled-jsx/loader-utils": "1.4.2",
        "@babel/plugin-transform-modules-systemjs": "7.29.4",
        "fast-uri": "3.1.2",
        "follow-redirects": "1.16.0",
        "ip-address": "10.2.0",
        "lodash": "4.18.1",
        "postcss": "8.5.15",
        "@babel/helpers": "^7.26.10",
        "@babel/runtime": "^7.26.10",
        "@commitlint/config-validator/ajv": "^8.18.0",
        "@eslint/eslintrc/minimatch": "^3.1.4",
        "@humanwhocodes/config-array/minimatch": "^3.1.4",
        "eslint-plugin-import/minimatch": "^3.1.4",
        "eslint-plugin-react/minimatch": "^3.1.4",
        "@typescript-eslint/typescript-estree/minimatch": "^9.0.7",
        "glob/minimatch": "^9.0.7",
        "micromatch/picomatch": "^2.3.2",
        "jest-util/picomatch": "^2.3.2",
        "tinyglobby/picomatch": "^4.0.4",
        "cacache/tar": "^7.5.11",
        "node-gyp/tar": "^7.5.11",
        "cacache/glob": "^10.5.0",
        "node-gyp/glob": "^10.5.0",
        "rimraf/glob": "^10.5.0",
        "eslint/minimatch": "^3.1.4",
        "test-exclude/minimatch": "^3.1.4",
        "eslint/ajv": "^6.14.0",
        "@eslint/eslintrc/ajv": "^6.14.0",
        "anymatch/picomatch": "^2.3.2",
        "@apidevtools/json-schema-ref-parser/js-yaml": "^4.1.1",
        "cosmiconfig/js-yaml": "^4.1.1",
        "cosmiconfig/yaml": "^1.10.3",
        "execa/cross-spawn": "^6.0.6",
        "@commitlint/is-ignored/semver": "^7.5.2",
        "@istanbuljs/load-nyc-config/js-yaml": "^3.14.2",
        "eslint/js-yaml": "^4.1.1",
        "@eslint/eslintrc/js-yaml": "^4.1.1",
        "flat-cache/flatted": "^3.4.2",
        "tough-cookie": "^4.1.3"
    }
}
